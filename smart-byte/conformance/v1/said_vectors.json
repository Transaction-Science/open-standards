    "canonical_cbor_hex": "a6677665727369",
    "expected_said": "EAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA"
  },
  {
    "name": "said-002-usd-cargo",
