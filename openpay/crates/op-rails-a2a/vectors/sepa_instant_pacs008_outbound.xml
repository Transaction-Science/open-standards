      <NbOfTxs>1</NbOfTxs>
      <SttlmInf><SttlmMtd>CLRG</SttlmMtd></SttlmInf>
      <InstgAgt><FinInstnId><BICFI>DEUTDEFFXXX</BICFI></FinInstnId></InstgAgt>
    </GrpHdr>
    <CdtTrfTxInf>
      <PmtId>
        <InstrId>RECH4242</InstrId>
        <EndToEndId>RECH4242</EndToEndId>
        <UETR>12a345b6-7c89-4d01-23e4-567890abcdef</UETR>
      </PmtId>
      <PmtTpInf><LclInstrm><Cd>INST</Cd></LclInstrm><SvcLvl><Cd>SEPA</Cd></SvcLvl></PmtTpInf>
